        android:pathData="M 63.7,67.35 m -3.96,0 a 3.96,3.96 0 1,0 7.92,0 a 3.96,3.96 0 1,0 -7.92,0 Z" />
    <path
        android:fillColor="#F7C688"
        android:pathData="M 44.3,67.35 m -3.96,0 a 3.96,3.96 0 1,0 7.92,0 a 3.96,3.96 0 1,0 -7.92,0 Z" />
    <path
